# ===================================================
# .env.example — Contoh variabel lingkungan
# Salin file ini menjadi .env.local dan isi nilainya
# JANGAN commit .env.local ke Git!
# ===================================================

# Nama aplikasi (opsional, untuk referensi)
NEXT_PUBLIC_SITE_NAME="PT Adiguna Cakra Semesta"
NEXT_PUBLIC_SITE_URL="https://acs-indonesia.com"

# ===================================================
# KONFIGURASI EMAIL (Resend - untuk form kontak)
# Daftar gratis di: https://resend.com
# ===================================================
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Email tujuan penerima pesan dari form kontak
# CONTACT_EMAIL_TO=adiguna@acs-indonesia.com

# ===================================================
# GOOGLE MAPS (untuk menampilkan peta lokasi)
# Dapatkan API key dari: https://console.cloud.google.com
# ===================================================
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxx

# ===================================================
# GOOGLE ANALYTICS (opsional, untuk melacak traffic)
# ===================================================
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
